  "features": [
    "Custom Mode modifiers page — all 16 modifiers with deck replacement tags and Neow interaction notes",
    "Potion stats on Community Meta — pick rate, usage count, win% with hover tooltips",
    "Relic stats table matching card stats — sortable by Runs/Win%/Name, chart/table toggle",
    "Multi-file .run upload with progress bar — select multiple files at once",
    "Browse Runs — username search filter, cache-busting for real-time updates",
    "Optional username field on run submissions (25 char max, sanitized)",
    "Run viewer URL updates to /runs/{hash} for direct sharing"
  ],
  "fixes": [
    "Fixed 20 cards with missing damage (CalculatedDamage — Ashen Strike, Body Slam, Perfected Strike, Rend, etc.)",
    "Fixed CalculatedDamage showing base+extra instead of just base value to match in-game display",
    "Fixed Gunk Up missing hit count (3 hits) — now shows 4 x 3 DMG",
    "Fixed Sword Boomerang+ upgrade text not changing '3 times' to '4 times'",
    "Fixed Hologram+ not showing Exhaust keyword removal on upgrade",
    "Fixed Coolheaded+ upgrade replacing wrong number in description (ambiguous value detection)",
    "Fixed DMG badge spacing — '3 x4' now shows '3 × 4' with proper multiplication sign",
    "Fixed false X-cost flag on Bullet Time, All for One, Scrape, Transfigure",
    "Fixed Spur+ showing 7 instead of 5 (cascading replacement bug in upgrade text)",
    "Fixed POTION. double prefix in meta stats",
    "Fixed 'Killed by NONE.NONE' — hidden for wins and abandoned runs",
    "Fixed share button not appearing for duplicate run submissions",
    "Fixed meta page tooltips clipped by table overflow",
    "Fixed run dedup hash to prevent duplicates when seed is empty",
    "Improved Darv ancient pool condition text for Pandora's Box"
  ],
  "api_changes": [
    "GET /api/runs/list — browse submitted runs with character, win, username filters",
    "GET /api/runs/stats — now includes potion stats (offered, picked, used, win%)",
    "POST /api/runs — optional ?username= parameter, POTION. prefix stripped on storage"
  ]
}